{
  "name": "Clean Workflow",
  "nodes": [
    {
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "credentials": {"httpHeaderAuth": "wh_creds"},
      "parameters": {"authentication": "headerAuth"}
    },
    {
      "id": "2",
      "name": "Validate Input",
      "type": "n8n-nodes-base.set",
      "parameters": {"values": {"sanitize": "trim"}}
    },
    {
      "id": "3",
      "name": "Lookup",
      "type": "n8n-nodes-base.postgres",
      "credentials": {"postgres": "pg_creds"},
      "parameters": {"operation": "select"}
    },
    {
      "id": "4",
      "name": "Reply",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "credentials": {"openAiApi": "oai"},
      "parameters": {"temperature": 0}
    },
    {
      "id": "5",
      "name": "On Error",
      "type": "n8n-nodes-base.errorTrigger",
      "parameters": {}
    }
  ],
  "connections": {
    "Webhook": {"main": [[{"node": "Validate Input", "type": "main", "index": 0}]]},
    "Validate Input": {
      "main": [[
        {"node": "Lookup", "type": "main", "index": 0},
        {"node": "Reply", "type": "main", "index": 0}
      ]]
    }
  }
}
