{
  "name": "Customer Onboarding",
  "nodes": [
    {
      "id": "1",
      "name": "Intake Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": {}
    },
    {
      "id": "2",
      "name": "Process Form",
      "type": "n8n-nodes-base.code",
      "parameters": {"jsCode": "return items"}
    },
    {
      "id": "3",
      "name": "MySQL Query",
      "type": "n8n-nodes-base.mySql",
      "parameters": {"operation": "INSERT INTO accounts VALUES (?, ?)", "password": "supersecret123"}
    },
    {
      "id": "4",
      "name": "Send Email",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {"method": "POST", "url": "https://api.mail.example/{{ $json.user }}/send"}
    },
    {
      "id": "5",
      "name": "Reply with LLM",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "parameters": {"model": "gpt-4o"}
    }
  ],
  "connections": {
    "Intake Webhook": {"main": [[{"node": "Process Form", "type": "main", "index": 0}]]},
    "Process Form": {
      "main": [[
        {"node": "MySQL Query", "type": "main", "index": 0},
        {"node": "Reply with LLM", "type": "main", "index": 0},
        {"node": "Send Email", "type": "main", "index": 0}
      ]]
    }
  }
}
